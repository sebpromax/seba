# Copie ce fichier en ".env" (a la racine du repo) et remplace les valeurs.
# ".env" est gitignore -> ne sera jamais commite/pousse.
# Ne jamais coller de vraie cle API dans le chat, un commit, ou un fichier suivi par git.

GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Deploiement (voir agents_config.json -> safety) : par defaut l'orchestrateur
# pousse la branche + ouvre une vraie Pull Request (gh pr create). Decommente
# pour changer de comportement :
# SEBA_ORCH_ALLOW_PR=false        # repasse en local uniquement, aucune PR
# SEBA_ORCH_ALLOW_PUSH_MAIN=true  # DANGEREUX : merge + push direct sur main (prod)
